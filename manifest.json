{
  "manifest_version": 3,
  "name": "Google Maps Listing Scraper",
  "version": "1.0.0",
  "description": "Scrape Google Maps search listings and export as CSV or JSON.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.google.com/maps/*"],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/search/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Maps Scraper"
  }
}
